<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101114">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAiBack"
                android:layout_width="86dp"
                android:layout_height="48dp"
                android:backgroundTint="#383A40"
                android:text="返回"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="AI 學習助理"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_recent_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI 課堂整理模式"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="基於行為標籤與 OCR 文字進行本地規則式整理；不依賴雲端 AI 或大型模型。"
                android:textColor="#D8DDE6"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="開始整理"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAiOcrCamera"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#2A2D33"
                android:text="拍照 OCR"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAiOcrGallery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:backgroundTint="#2A2D33"
                android:text="導入圖片"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAiClearText"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#2A2D33"
                android:text="清除"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="一鍵標籤化"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTypeLecture"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnTypeHomework"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnTypeReport"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTypeExam"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnTypeGeneral"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="OCR 原文 / 貼上文字"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtAiOcrText"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search"
            android:gravity="top"
            android:hint="貼上 OCR 文字，或使用上方拍照/導入圖片。"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F929A"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnAiAnalyze"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#55C3A8"
            android:text="分析文字並產生整理"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/txtAiEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_recent_panel"
            android:padding="14dp"
            android:textColor="#D8DDE6"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/layoutAiResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="文件類型建議"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAiType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recent_panel"
                android:padding="14dp"
                android:textColor="#D8DDE6"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="智慧命名建議"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAiName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recent_panel"
                android:padding="14dp"
                android:textColor="#D8DDE6"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnAiCopyName"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#2A2D33"
                android:text="複製命名建議"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="重點整理"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAiSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recent_panel"
                android:padding="14dp"
                android:textColor="#D8DDE6"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="關鍵字"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAiKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recent_panel"
                android:padding="14dp"
                android:textColor="#D8DDE6"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="複習題"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAiQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_recent_panel"
                android:padding="14dp"
                android:textColor="#D8DDE6"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
