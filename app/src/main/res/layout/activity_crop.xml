<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#202124"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btnCropBack"
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="‹"
            android:textColor="#FFFFFF"
            android:textSize="42sp" />

        <TextView
            android:id="@+id/txtCropTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="裁剪"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="26dp">

        <ImageView
            android:id="@+id/imgCropPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="#000000"
            android:scaleType="fitCenter" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_crop_frame">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="44dp"
                android:layout_height="14dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="14dp"
                android:layout_height="44dp"
                android:layout_gravity="center_vertical|start"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="14dp"
                android:layout_height="44dp"
                android:layout_gravity="center_vertical|end"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|start"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="44dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/bg_crop_handle" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_crop_handle" />
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:background="@drawable/bg_scan_panel"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCropRotateLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↶\n左轉"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnCropRotateRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↷\n右轉"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnCropAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⛶\n全部"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnCropNext"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="→\n下一步"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
