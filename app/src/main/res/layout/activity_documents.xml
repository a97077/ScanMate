<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2B2B2E">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="86dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="全部文檔"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtSearchDocuments"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search"
                android:hint="搜尋文件"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#8F929A"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtDocumentCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="共 0 份文件"
                    android:textColor="#B8BDC8"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnImportPdf"
                    android:layout_width="100dp"
                    android:layout_height="46dp"
                    android:backgroundTint="#55C3A8"
                    android:text="導入 PDF"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnClearDocuments"
                    android:layout_width="86dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#4A4B50"
                    android:text="清空"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtDocumentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_search"
                android:padding="16dp"
                android:text="尚無文件，請從智慧掃描儲存 PDF 或導入既有 PDF"
                android:textColor="#A4A6AD"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutDocumentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/docsNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="首頁"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/docsNavDocuments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="全部文檔"
            android:textColor="#55C3A8"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/docsNavToolbox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="工具箱"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/docsNavMe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="我的"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
