<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101114">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTextBack"
                android:layout_width="86dp"
                android:layout_height="48dp"
                android:backgroundTint="#383A40"
                android:text="返回"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="提取文字"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtTextReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_search"
            android:padding="14dp"
            android:text="選擇圖片後會產生 OCR 前處理預覽與文字區塊報告。"
            android:textColor="#D8DDE6"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSelectTextImage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#55C3A8"
            android:text="選擇圖片"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCaptureTextImage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#4E8FDE"
            android:text="拍照辨識"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnExportOcrText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#4A4B50"
            android:text="匯出文字"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSendToAiStudy"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#5E8DF5"
            android:text="送到 AI 學習助理"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <ImageView
            android:id="@+id/imgTextPreview"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_marginTop="16dp"
            android:background="#1C1D22"
            android:contentDescription="文字提取預處理預覽"
            android:scaleType="fitCenter" />
    </LinearLayout>
</ScrollView>
