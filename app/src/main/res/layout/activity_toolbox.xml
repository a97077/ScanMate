<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2B2B2E">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="86dp">

        <LinearLayout
            android:id="@+id/layoutToolboxContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工具箱"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_search"
                    android:gravity="center"
                    android:text="新功能"
                    android:textColor="#55C3A8"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="搜"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/toolboxNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="首頁"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/toolboxNavDocuments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="全部文檔"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/toolboxNavToolbox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="工具箱"
            android:textColor="#55C3A8"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/toolboxNavMe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="我的"
            android:textColor="#B8B8BB"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
